<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Gray PowerShell UI Template"
    Width="1080"
    Height="760"
    MinWidth="940"
    MinHeight="680"
    WindowStartupLocation="CenterScreen"
    Background="#666A70">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#666A70"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#7A7F86"/>
        <SolidColorBrush x:Key="CardBrush" Color="#ECEDEE"/>
        <SolidColorBrush x:Key="CardAltBrush" Color="#D7D9DD"/>
        <SolidColorBrush x:Key="BorderBrushGray" Color="#AEB3BA"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#26292D"/>
        <SolidColorBrush x:Key="TextSoftBrush" Color="#50545A"/>
        <SolidColorBrush x:Key="HighlightBrush" Color="#8D939A"/>
        <SolidColorBrush x:Key="TabBrush" Color="#8C9198"/>

        <Style TargetType="TextBlock" x:Key="SectionLabel">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#F9F9FA"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#F9F9FA"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,16,8"/>
        </Style>

        <Style TargetType="Button" x:Key="SoftButton">
            <Setter Property="Background" Value="#53575D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#45494F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#34373B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="{StaticResource TabBrush}"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#ECEDEE"/>
                                <Setter Property="Foreground" Value="#26292D"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#9AA0A7"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#ECEDEE"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#7A7F86" CornerRadius="12" Padding="22" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Gray PowerShell UI Template"
                               Foreground="White"
                               FontFamily="Segoe UI Semibold"
                               FontSize="24"/>
                    <TextBlock Text="A reusable tabbed layout showing common WPF elements for PowerShell tools."
                               Foreground="#ECEDEE"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#8B9097"
                        CornerRadius="10"
                        Padding="14"
                        HorizontalAlignment="Right">
                    <StackPanel>
                        <TextBlock Text="Template Notes" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Use the tabs to preview forms, tables, lists, and output panels."
                                   Foreground="#F3F4F4"
                                   FontSize="11"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="tabMain" Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="Overview">
                <Border Background="#ECEDEE" CornerRadius="0,12,12,12" Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Background="#D7D9DD" CornerRadius="10" Padding="16" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Quick Summary" Style="{StaticResource SectionLabel}" Foreground="#26292D"/>
                                    <TextBlock Text="This panel can hold high-level stats, action buttons, or setup text for your script."
                                               Foreground="#50545A"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <UniformGrid Columns="3" Margin="0,0,0,14">
                                <Border Background="#F7F7F8" BorderBrush="#C4C8CE" BorderThickness="1" CornerRadius="10" Margin="0,0,10,0" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="12" FontSize="28" FontWeight="Bold" Foreground="#26292D"/>
                                        <TextBlock Text="Sample Projects" Foreground="#5C6067" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F7F7F8" BorderBrush="#C4C8CE" BorderThickness="1" CornerRadius="10" Margin="0,0,10,0" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="4" FontSize="28" FontWeight="Bold" Foreground="#26292D"/>
                                        <TextBlock Text="Active Tabs" Foreground="#5C6067" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F7F7F8" BorderBrush="#C4C8CE" BorderThickness="1" CornerRadius="10" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="80%" FontSize="28" FontWeight="Bold" Foreground="#26292D"/>
                                        <TextBlock Text="Example Completion" Foreground="#5C6067" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <GroupBox Header="Header Content">
                                <StackPanel>
                                    <TextBlock Text="Window Title" Foreground="#50545A" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtHeaderTitle"/>
                                    <TextBlock Text="Subtitle" Foreground="#50545A" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtHeaderSubtitle" Height="58" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <GroupBox Header="General Options">
                                <StackPanel>
                                    <TextBlock Text="Category" Foreground="#50545A" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbCategory"/>
                                    <CheckBox x:Name="chkFeatureA" Content="Enable feature toggle"/>
                                    <CheckBox x:Name="chkFeatureB" Content="Use compact mode"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <RadioButton x:Name="rbModeBasic" Content="Basic mode" GroupName="ModeGroup"/>
                                        <RadioButton x:Name="rbModeAdvanced" Content="Advanced mode" GroupName="ModeGroup"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Actions">
                                <StackPanel>
                                    <TextBlock Text="These buttons show simple event wiring you can reuse." Foreground="#50545A" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                    <WrapPanel>
                                        <Button x:Name="btnPrimary" Content="Save Sample" Style="{StaticResource SoftButton}"/>
                                        <Button x:Name="btnSecondary" Content="Open Data Tab" Style="{StaticResource SoftButton}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button x:Name="btnResetForm" Content="Reset Form" Style="{StaticResource SoftButton}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Form Elements">
                <Border Background="#ECEDEE" CornerRadius="0,12,12,12" Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Input Examples" Grid.Column="0">
                            <StackPanel>
                                <TextBlock Text="Project Name" Foreground="#50545A" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtName"/>
                                <TextBlock Text="Folder Path" Foreground="#50545A" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtPath"/>
                                <TextBlock Text="Theme" Foreground="#50545A" Margin="0,0,0,4"/>
                                <ComboBox x:Name="cmbTheme"/>
                                <TextBlock Text="Due Date" Foreground="#50545A" Margin="0,0,0,4"/>
                                <DatePicker x:Name="dpDueDate"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Interactive Controls" Grid.Column="2">
                            <StackPanel>
                                <TextBlock Text="Priority" Foreground="#50545A" Margin="0,0,0,6"/>
                                <Slider x:Name="sliderPriority" Minimum="0" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False"/>
                                <DockPanel Margin="0,8,0,0">
                                    <ProgressBar x:Name="pbPriority" Height="18" Minimum="0" Maximum="100" Value="40" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="lblPriorityValue" Width="48" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#26292D" Text="40%"/>
                                </DockPanel>
                                <TextBlock Text="Use this section for sliders, progress bars, or selection controls." Foreground="#50545A" Margin="0,12,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Data">
                <Border Background="#ECEDEE" CornerRadius="0,12,12,12" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtSearch" Grid.Column="0" Margin="0"/>
                            <Button x:Name="btnRefreshData" Grid.Column="2" Content="Refresh Data" Style="{StaticResource SoftButton}" Margin="0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="Quick Items" Grid.Column="0">
                                <ListBox x:Name="lstQuickItems" Background="#F9F9FA" BorderBrush="#C4C8CE" BorderThickness="1"/>
                            </GroupBox>

                            <GroupBox Header="Recent Items" Grid.Column="2">
                                <DataGrid x:Name="dgRecentItems"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowBackground="#FAFAFB"
                                          AlternatingRowBackground="#F0F1F3"
                                          BorderBrush="#C4C8CE"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="120"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140"/>
                                        <DataGridTextColumn Header="Modified" Binding="{Binding Modified}" Width="140"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Output">
                <Border Background="#ECEDEE" CornerRadius="0,12,12,12" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Margin="0,0,0,14">
                            <Button x:Name="btnAddLogEntry" Content="Add Log Entry" Style="{StaticResource SoftButton}"/>
                            <Button x:Name="btnClearLog" Content="Clear Log" Style="{StaticResource SoftButton}"/>
                        </WrapPanel>

                        <TextBox x:Name="txtLog"
                                 Grid.Row="1"
                                 Background="#F9F9FA"
                                 BorderBrush="#C4C8CE"
                                 BorderThickness="1"
                                 FontFamily="Consolas"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 IsReadOnly="True"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#7A7F86" CornerRadius="10" Padding="14" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblStatus" Foreground="White" VerticalAlignment="Center" Text="Ready."/>
                <ProgressBar x:Name="pbTask" Grid.Column="1" Height="16" Minimum="0" Maximum="100" Value="25" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>