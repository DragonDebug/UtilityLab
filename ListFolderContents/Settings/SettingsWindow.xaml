<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="List Folder Contents | Settings"
    Width="400" SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#3861FB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A50DC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2344C3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="Foreground" Value="#646C78"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Tb" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="#181C24"/>
            <Setter Property="Background" Value="#F8F9FB"/>
            <Setter Property="BorderBrush" Value="#CDD2DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" Margin="16,14,16,14" Padding="18,14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.07" Color="Black"/>
        </Border.Effect>
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Settings" FontFamily="Segoe UI" FontWeight="Bold" FontSize="15" Foreground="#181C24"/>
            <TextBlock Text="Configure how folder contents are listed"
                       FontFamily="Segoe UI" FontSize="10" Foreground="#A0AAB9" Margin="0,2,0,12"/>

            <!-- Filter -->
            <TextBlock Text="FILE FILTER" Style="{StaticResource Lbl}"/>
            <RadioButton x:Name="rbAll" Content="All files"
                         FontFamily="Segoe UI" FontSize="11.5" Foreground="#181C24"
                         Cursor="Hand" GroupName="Filter" Margin="0,1,0,0"/>
            <RadioButton x:Name="rbExtension" Content="Only specific extensions"
                         FontFamily="Segoe UI" FontSize="11.5" Foreground="#181C24"
                         Cursor="Hand" GroupName="Filter" Margin="0,4,0,0"/>
            <TextBlock Text="EXTENSIONS (comma-separated)" Style="{StaticResource Lbl}" Margin="0,8,0,4"/>
            <TextBox x:Name="txtExtensions" Style="{StaticResource Tb}"/>

            <!-- Options -->
            <TextBlock Text="OPTIONS" Style="{StaticResource Lbl}" Margin="0,10,0,4"/>
            <CheckBox x:Name="chkFolders" Content="Include folder names"
                      FontFamily="Segoe UI" FontSize="11.5" Foreground="#181C24" Cursor="Hand" Margin="0,1,0,0"/>
            <CheckBox x:Name="chkSubfolders" Content="Include subfolders (recursive)"
                      FontFamily="Segoe UI" FontSize="11.5" Foreground="#181C24" Cursor="Hand" Margin="0,4,0,0"/>

            <!-- Output -->
            <TextBlock Text="OUTPUT FILE NAME" Style="{StaticResource Lbl}" Margin="0,10,0,4"/>
            <TextBox x:Name="txtOutputName" Style="{StaticResource Tb}"/>

            <!-- Footer -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblStatus" Grid.Column="0" FontFamily="Segoe UI" FontSize="10.5"
                           Foreground="#10984F" VerticalAlignment="Center"/>
                <Button x:Name="btnSave" Grid.Column="1" Content="Save" Style="{StaticResource AccentButton}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
